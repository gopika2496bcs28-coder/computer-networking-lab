#include <stdio.h>

int main() {
    int t;
    if (scanf("%d", &t) != 1) {
        return 0;
        }
    while(t>0){
    char s[1005];
    scanf("%s",s);
    int sum=0;
    for(int i=0;s[i]!='\0';i++){
        if(s[i]>= '0' && s[i]<= '9'){
            sum=sum + (s[i] - '0');
        }
    }
    printf("%d\n",sum);
    t--;
    }
}

